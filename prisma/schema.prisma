// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Leads / Booking Requests ────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  CONFIRMED
  REJECTED
  ARCHIVED
}

model Lead {
  id            String     @id @default(cuid())
  fullName      String
  email         String
  phone         String?
  eventType     String
  budgetRange   String?
  message       String?
  status        LeadStatus @default(NEW)
  internalNotes String?

  activities LeadActivity[]
  emailLogs  EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model LeadActivity {
  id      String @id @default(cuid())
  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type    String // STATUS_CHANGE | NOTE_ADDED | EMAIL_SENT | CREATED
  content String?

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model EmailLog {
  id      String @id @default(cuid())
  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject String
  body    String
  sentAt  DateTime @default(now())

  @@index([leadId])
}

// ─── Shows ───────────────────────────────────────────────────────────────────

enum ShowStatus {
  UPCOMING
  SOLD_OUT
  ANNOUNCED
  CANCELLED
  PAST
}

model Show {
  id         String     @id @default(cuid())
  date       DateTime
  venue      String
  city       String
  country    String     @default("US")
  type       String     // Festival, Venue Show, Private Event, etc.
  status     ShowStatus @default(UPCOMING)
  ticketUrl  String?
  isArchived Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, isArchived])
}

// ─── Merch ───────────────────────────────────────────────────────────────────

model MerchItem {
  id          String  @id @default(cuid())
  name        String
  price       Float
  description String?
  image       String?
  category    String?
  inStock     Boolean @default(true)
  isVisible   Boolean @default(true)
  isArchived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isArchived, isVisible])
}
